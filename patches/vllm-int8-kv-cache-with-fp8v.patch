+@triton.jit
+def fp8_e4m3_decode_from_int8(x_i8):
+    """Decode emulated FP8 E4M3 byte codes stored in int8 tensors.
+
+    Format: 1 sign bit + 4 exponent bits + 3 mantissa bits
+    Range: [-448, 448] (no inf/NaN - encoder saturates at max normal)
+    """
+    x_i32 = x_i8.to(tl.int32)
+    x_u8 = tl.where(x_i32 < 0, x_i32 + 256, x_i32)
+    sign = (x_u8 >> 7) & 0x1
+    exp_bits = (x_u8 >> 3) & 0xF
+    mant_bits = x_u8 & 0x7
+
+    mant_f = mant_bits.to(tl.float32) * 0.125
+    normal = (1.0 + mant_f) * tl.exp2(exp_bits.to(tl.float32) - 7.0)
+    subnormal = mant_f * tl.exp2(-6.0)
+
+    val = tl.where(exp_bits == 0, subnormal, normal)
+    return tl.where(sign == 1, -val, val)
+
