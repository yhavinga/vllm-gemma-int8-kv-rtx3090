# INT8-K + FP8-V KV Cache Patch for vLLM 0.17.1
#
# Enables quantized KV cache for Ampere GPUs (RTX 3090) that lack FP8 hardware:
# - K (keys): INT8 symmetric quantization (stable, 5.8x range)
# - V (values): FP8-E4M3 emulated in INT8 storage (handles 340x range)
#
# Both use per-layer scales for optimal precision.
#
# Apply to your vLLM installation:
#   patch -p1 -d $(python -c "import vllm; print(vllm.__path__[0])") < patches/vllm-int8-kv-cache-with-fp8v.patch
#
# Enable FP8-V emulation at runtime:
#   export VLLM_INT8_V_FP8_EMUL=1
#
# Without the env var, both K and V use INT8 (simpler, still good quality).

--- a/config/cache.py
+++ b/config/cache.py
@@ -23,6 +23,7 @@ CacheDType = Literal[
     "fp8_e4m3",
     "fp8_e5m2",
     "fp8_inc",
     "fp8_ds_mla",
+    "int8",  # INT8 KV cache for Ampere GPUs (RTX 3090)
 ]

--- a/v1/attention/backend.py
+++ b/v1/attention/backend.py
@@ -922,7 +922,7 @@ def is_quantized_kv_cache(kv_cache_dtype: str) -> bool:
     """Check if the KV cache dtype is quantized (FP8 or INT8).
     Used by attention backends to determine if dequantization is needed.
     """
-    return kv_cache_dtype.startswith("fp8")
+    return kv_cache_dtype.startswith("fp8") or kv_cache_dtype == "int8"

