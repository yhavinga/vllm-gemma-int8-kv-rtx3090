 from vllm.platforms import current_platform
 from vllm.triton_utils import tl, triton


+@triton.jit
+def _fp8_e4m3_encode_to_int8(x):
+    """Encode normalized float32 values to emulated FP8 E4M3 byte codes in int8.
+
+    FP8-E4M3 format: 1 sign + 4 exponent + 3 mantissa bits
+    Range: [-448, 448] with logarithmic precision spacing
+
+    This handles the 340x variance in V activations better than linear INT8.
+    """
+    x = x.to(tl.float32)
+    ax = tl.abs(x)
+    sign = x < 0
+    is_zero = ax < 1e-7
+    is_normal = ax >= 0.015625  # 2^-6
+
+    # Normal number encoding
+    exp_q = tl.floor(tl.log2(tl.maximum(ax, 1e-7)))
+    exp_q = tl.maximum(tl.minimum(exp_q, 7.0), -6.0)
+
+    mant = ax / tl.exp2(exp_q) - 1.0
+    mant_q = tl.floor(mant * 8.0 + 0.5)
+    carry = mant_q >= 8.0
+    mant_q = tl.where(carry, 0.0, mant_q)
+    exp_q = tl.where(carry, tl.minimum(exp_q + 1.0, 7.0), exp_q)
+
+    exp_bits = (exp_q + 7.0).to(tl.int32)
+    mant_bits = mant_q.to(tl.int32)
+
+    # Subnormal quantization: value ~= mant/8 * 2^-6
+    sub_mant = tl.floor(ax * 512.0 + 0.5)  # 2^9
+    sub_mant = tl.maximum(tl.minimum(sub_mant, 7.0), 0.0).to(tl.int32)
+
+    exp_bits = tl.where(is_normal, exp_bits, 0)
+    mant_bits = tl.where(is_normal, mant_bits, sub_mant)
+    exp_bits = tl.where(is_zero, 0, exp_bits)
+    mant_bits = tl.where(is_zero, 0, mant_bits)
+
+    sign_bits = tl.where(sign, 1, 0).to(tl.int32)
+    byte_u8 = (sign_bits << 7) | (exp_bits << 3) | mant_bits
+    byte_i8 = tl.where(byte_u8 >= 128, byte_u8 - 256, byte_u8)
+    return byte_i8.to(tl.int8)
+
