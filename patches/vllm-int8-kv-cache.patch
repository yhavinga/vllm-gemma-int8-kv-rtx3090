# INT8 KV Cache Patch for vLLM 0.17.1
# Enables INT8 quantized KV cache for Ampere GPUs (RTX 3090) that lack FP8 hardware
#
# Apply to your vLLM installation:
#   patch -p1 -d $(python -c "import vllm; print(vllm.__path__[0])") < patches/vllm-int8-kv-cache.patch
#
# Or manually edit the files as shown below.

--- a/config/cache.py
+++ b/config/cache.py
@@ -23,6 +23,7 @@ CacheDType = Literal[
     "fp8_e4m3",
     "fp8_e5m2",
     "fp8_inc",
     "fp8_ds_mla",
+    "int8",  # INT8 KV cache for Ampere GPUs (RTX 3090)
 ]

--- a/v1/attention/backend.py
+++ b/v1/attention/backend.py
@@ -922,7 +922,7 @@ def is_quantized_kv_cache(kv_cache_dtype: str) -> bool:
     """Check if the KV cache dtype is quantized (FP8 or INT8).
     Used by attention backends to determine if dequantization is needed.
     """
-    return kv_cache_dtype.startswith("fp8")
+    return kv_cache_dtype.startswith("fp8") or kv_cache_dtype == "int8"

--- a/v1/attention/backends/triton_attn.py
+++ b/v1/attention/backends/triton_attn.py
@@ -264,6 +264,7 @@ class TritonFlashAttentionBackend(AttentionBackend):
         "fp8",
         "fp8_e4m3",
         "fp8_e5m2",
+        "int8",  # INT8 KV cache for Ampere GPUs
     ]

--- a/v1/attention/ops/triton_reshape_and_cache_flash.py
+++ b/v1/attention/ops/triton_reshape_and_cache_flash.py
@@ -31,6 +31,7 @@ def _reshape_and_cache_flash_kernel(
     stride_vn: tl.constexpr,
     stride_vd: tl.constexpr,
     FP8_KV_CACHE: tl.constexpr,
+    INT8_KV_CACHE: tl.constexpr,
     USE_FP8_SCALES: tl.constexpr,
     KV_CACHE_DTYPE: tl.constexpr,
     HEAD_SIZE: tl.constexpr,
@@ -82,6 +83,11 @@ def _reshape_and_cache_flash_kernel(
     if FP8_KV_CACHE:
         key_tile = key_load.to(KV_CACHE_DTYPE)
         value_tile = value_load.to(KV_CACHE_DTYPE)
+    elif INT8_KV_CACHE:
+        # INT8 quantization: scale, round, clamp to [-128, 127]
+        key_scaled = key_load.to(tl.float32) / tl.load(k_scale)
+        key_rounded = tl.extra.cuda.libdevice.round(key_scaled)
+        key_tile = tl.maximum(tl.minimum(key_rounded, 127.0), -128.0).to(tl.int8)
     else:
         key_tile = key_load
         value_tile = value_load
@@ -100,6 +106,11 @@ def _reshape_and_cache_flash_kernel(
         ...
     elif FP8_KV_CACHE:
         value_tile = value_load.to(KV_CACHE_DTYPE)
+    elif INT8_KV_CACHE:
+        # INT8 quantization: scale, round, clamp to [-128, 127]
+        value_scaled = value_load.to(tl.float32) / tl.load(v_scale)
+        value_rounded = tl.extra.cuda.libdevice.round(value_scaled)
+        value_tile = tl.maximum(tl.minimum(value_rounded, 127.0), -128.0).to(tl.int8)
     else:
         value_tile = value_load

# In reshape_and_cache_flash() function, add INT8 dtype handling:
@@ -159,6 +170,9 @@ def reshape_and_cache_flash(...):
     if kv_cache_dtype.startswith("fp8"):
         kv_cache_torch_dtype = ...
+    elif kv_cache_dtype == "int8":
+        kv_cache_torch_dtype = torch.int8

+    INT8_KV_CACHE = kv_cache_dtype == "int8"
     # Pass INT8_KV_CACHE to kernel call

--- a/v1/attention/ops/triton_unified_attention.py
+++ b/v1/attention/ops/triton_unified_attention.py
@@ -105,6 +105,7 @@ def _unified_attention_kernel(
     BLOCK_D: tl.constexpr,
     USE_ALIBI: tl.constexpr,
     FP8_KV_CACHE: tl.constexpr,
+    INT8_KV_CACHE: tl.constexpr,  # bool - INT8 quantized KV cache
     KV_CACHE_DTYPE: tl.constexpr,
     ...
 ):
@@ -265,6 +266,9 @@ def _unified_attention_kernel(
         if FP8_KV_CACHE:
             K = (K_load.to(tl.float32) * tl.load(k_scale)).to(Q.dtype)
             V = (V_load.to(tl.float32) * tl.load(v_scale)).to(Q.dtype)
+        elif INT8_KV_CACHE:
+            # INT8 dequantization: multiply by scale
+            K = (K_load.to(tl.float32) * tl.load(k_scale)).to(Q.dtype)
+            V = (V_load.to(tl.float32) * tl.load(v_scale)).to(Q.dtype)
         else:
             K = K_load
             V = V_load

# Add INT8_KV_CACHE to all kernel invocations in unified_attention():
@@ -1055,6 +1059,7 @@ def unified_attention(...):
             ...
             FP8_KV_CACHE=k.dtype in (torch.float8_e4m3fn, ...),
+            INT8_KV_CACHE=k.dtype == torch.int8,
             ...
         )

--- a/model_executor/layers/attention/attention.py
+++ b/model_executor/layers/attention/attention.py
@@ -109,6 +109,13 @@ def set_default_quant_scales(layer: nn.Module, register_buffer: bool = False) ->
     """
     from vllm import envs

+    # Use INT8 range (127) when kv_cache_dtype is "int8", otherwise use env defaults (for FP8)
+    kv_cache_dtype = getattr(layer, 'kv_cache_dtype', 'auto')
+    if kv_cache_dtype == 'int8':
+        # INT8 symmetric quantization range is [-127, 127]
+        k_range_val = 127
+        v_range_val = 127
+    else:
         k_range_val = envs.K_SCALE_CONSTANT
         v_range_val = envs.V_SCALE_CONSTANT

@@ -496,6 +503,14 @@ class Attention(...):
         k_absmax = key.abs().amax()
         v_absmax = value.abs().amax()

+        # For INT8: if absmax is too small (warmup with zeros), use a reasonable
+        # default to avoid division by zero or tiny scales
+        is_int8 = hasattr(self, 'kv_cache_dtype') and self.kv_cache_dtype == 'int8'
+        if is_int8:
+            default_absmax = 20.0  # Typical range for transformer K/V
+            if k_absmax.item() < 0.01:
+                k_absmax = torch.tensor(default_absmax, device=k_absmax.device)
+            if v_absmax.item() < 0.01:
+                v_absmax = torch.tensor(default_absmax, device=v_absmax.device)
+
         self.k_scale.copy_(k_absmax / k_range_val)
         self.v_scale.copy_(v_absmax / v_range_val)
